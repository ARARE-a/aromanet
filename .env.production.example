# AromaNet production environment template.
# Do not commit real secrets.

DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl={\"rejectUnauthorized\":true}"
JWT_SECRET="replace-with-a-long-random-secret"
OAUTH_SERVER_URL=""
OWNER_OPEN_ID=""

# Optional analytics. Leave unset when not using analytics.
VITE_ANALYTICS_ENDPOINT=""
VITE_ANALYTICS_WEBSITE_ID=""

# Optional formal account setup inputs for:
#   pnpm prod:setup-accounts --apply
PROD_MARK_VERIFIED="1"
PROD_STORE_EMAIL=""
PROD_STORE_PASSWORD=""
PROD_STORE_NAME=""
PROD_THERAPIST_EMAIL=""
PROD_THERAPIST_PASSWORD=""
PROD_THERAPIST_NAME=""
PROD_THERAPIST_STORE_ID=""
PROD_CUSTOMER_EMAIL=""
PROD_CUSTOMER_PASSWORD=""
PROD_CUSTOMER_NAME=""

# Optional smoke cleanup markers for:
#   pnpm prod:cleanup-smoke --apply --recalculate-payroll
SMOKE_DATA_MARKERS="本番動作確認,動作確認"
